NEXT_PUBLIC_BASE_URL=http://localhost:3001
# Production: point at the API host (e.g. https://api.uptions.com). Business auth uses cookies + Bearer tokens across subdomains.
# Business dashboard calls the same API (e.g. POST /api/v1/business/onboarding).
# Admin app uses the same base URL; admin “password” is the backend ADMIN_API_KEY (see scripts/pre-mvp-admin-smoke.sh).
# Optional websocket base if you want real-time payment updates from backend:
# NEXT_PUBLIC_PAYMENT_WS_URL=ws://localhost:3001/ws/payments

